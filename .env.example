PORT=3000

# สำหรับ JWT สมาชิก (บังคับใน production — อย่างน้อย 16 ตัว)
JWT_SECRET=เปลี่ยนเป็นสตริงสุ่มยาวๆ

CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# Optional: แต้มหัวใจต่อรอบเกม (แสดงใน API /api/game/start เท่านั้น — ยังไม่หักจริง)
