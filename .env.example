PORT=3000

# PostgreSQL — ถ้าไม่ตั้ง ระบบจะใช้ไฟล์ data/users.json แทน (สมาชิกเท่านั้น; ออเดอร์บน DB จะไม่ทำงาน)
# DATABASE_URL=postgres://user:pass@host:5432/dbname
# บนเครื่อง dev ถ้า Postgres ไม่ใช้ SSL: DATABASE_SSL=false

# สำหรับ JWT สมาชิก (บังคับใน production — อย่างน้อย 16 ตัว)
JWT_SECRET=เปลี่ยนเป็นสตริงสุ่มยาวๆ

# สร้างแอดมินจาก env (ไม่ต้องสมัครผ่านเว็บ) — username + รหัส + เบอร์ 10 หลัก — หลังใช้แล้วลบทิ้ง
# BOOTSTRAP_ADMIN_USERNAME=myadmin
# BOOTSTRAP_ADMIN_PASSWORD=your-secure-password
# BOOTSTRAP_ADMIN_PHONE=0812345678

# (ไม่บังคับ) ตั้ง username ที่มีอยู่แล้วให้เป็น admin — ใช้เมื่อมีบัญชีสมาชิกอยู่แล้ว ไม่เปลี่ยนรหัส
# PROMOTE_ADMIN_USERNAME=myusername

CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# Optional: แต้มหัวใจต่อรอบเกม (แสดงใน API /api/game/start เท่านั้น — ยังไม่หักจริง)
# GAME_HEART_COST=10
