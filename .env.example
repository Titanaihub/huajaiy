PORT=3000

# PostgreSQL — ถ้าไม่ตั้ง ระบบจะใช้ไฟล์ data/users.json แทน (สมาชิกเท่านั้น; ออเดอร์บน DB จะไม่ทำงาน)
# DATABASE_URL=postgres://user:pass@host:5432/dbname
# บนเครื่อง dev ถ้า Postgres ไม่ใช้ SSL: DATABASE_SSL=false

# สำหรับ JWT สมาชิก (บังคับใน production — อย่างน้อย 16 ตัว)
JWT_SECRET=เปลี่ยนเป็นสตริงสุ่มยาวๆ

# โบนัสหัวใจชมพูเมื่อสมาชิกกดยืนยันเพิ่มเพื่อน LINE OA (ค่าเริ่มต้น 5)
# LINE_OA_FRIEND_BONUS_PINK=5

# ล็อกอิน LINE → JWT สมาชิก — ต้องตรงกับค่า LINE_LINK_SECRET บน Next (web)
# LINE_LINK_SECRET=สตริงสุ่มยาวอย่างน้อย-16-ตัว

# สร้างแอดมินจาก env (ไม่ต้องสมัครผ่านเว็บ) — หลังสร้างแล้วลบ BOOTSTRAP_ADMIN_PASSWORD (และถ้าต้องการ ลบทั้งสาม) เพื่อความปลอดภัย
# ตัวอย่างทดสอบ: ยูสเซอร์ admin รหัส 456789 — ตั้งบน huajaiy-api แล้ว redeploy ครั้งหนึ่ง
# BOOTSTRAP_ADMIN_USERNAME=admin
# BOOTSTRAP_ADMIN_PASSWORD=456789
# BOOTSTRAP_ADMIN_PHONE=0812345678

# (ไม่บังคับ) ตั้ง username ที่มีอยู่แล้วให้เป็น admin — ใช้เมื่อมีบัญชีสมาชิกอยู่แล้ว ไม่เปลี่ยนรหัส
# PROMOTE_ADMIN_USERNAME=myusername

# (ไม่บังคับ) ให้แอดมินกด「ดูหน้าสมาชิก (โหมดตรวจสอบ)」ได้ — หลังปล่อย production แนะนำลบหรือตั้งเป็น false
# ADMIN_IMPERSONATION_ENABLED=true

# เปิดสมัครสมาชิกแบบฟอร์ม (/register) — ค่าเริ่มต้นปิด (สมาชิกใหม่ใช้ LINE) ต้องตั้งเหมือนกันบน huajaiy-web ถ้าเปิดหน้าสมัคร
# ALLOW_PUBLIC_REGISTER=1

CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# Optional: แต้มหัวใจต่อรอบเกม (แสดงใน API /api/game/start เท่านั้น — ยังไม่หักจริง)
# GAME_HEART_COST=10
