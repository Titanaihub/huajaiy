# ใช้ทั้งอัปโหลด (ตรงไปยัง API) และเป็นเป้าหมายของ rewrite `/api/game/*` ใน Next
NEXT_PUBLIC_API_BASE_URL=https://api.huajaiy.com

# โดเมนเว็บจริง — ตั้งบน Render ให้ตรง URL ที่เปิดในเบราว์เซอร์ (ไม่มี / ท้าย) เพื่อ metadata / OG
# NEXT_PUBLIC_SITE_URL=https://huajaiy.com

# NextAuth — ตั้งค่า URL ให้ตรงโดเมนที่ deploy (มี HTTPS)
NEXTAUTH_URL=https://huajaiy-web.onrender.com
# จำเป็นใน production — ถ้าไม่มีจะ error "problem with the server configuration"
NEXTAUTH_SECRET=สร้างสตริงสุ่มยาวอย่างน้อย 32 ตัว
# หรือใช้ชื่อ AUTH_SECRET แทนได้ (โค้ดรองรับทั้งคู่)
# AUTH_SECRET=
# ตั้งเป็น 1 ชั่วคราวเพื่อดู log ใน Render เมื่อแก้ปัญหา NextAuth
# NEXTAUTH_DEBUG=1

# Facebook Login (Meta Developer Console)
FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=

# LINE Login (LINE Developers — Channel แบบ LINE Login)
LINE_CHANNEL_ID=
LINE_CHANNEL_SECRET=

# แลก LINE OAuth → JWT สมาชิก — สร้างสตริงสุ่มยาวอย่างน้อย 16 ตัว ใส่ค่าเดียวกันทั้งเว็บ (huajaiy-web) และ API (huajaiy-api)
LINE_LINK_SECRET=

# (ไม่บังคับ) ถ้าใน LINE Console ลงทะเบียน Callback เป็น /auth/line/callback ให้ใส่ URL เต็มให้ตรงกับที่ลงใน LINE (มี /auth/line/callback) — ระบบจะส่งต่อไป NextAuth ให้
# LINE_OAUTH_REDIRECT_URI=https://www.huajaiy.com/auth/line/callback

# เปิดหน้า /register (ฟอร์มสมัคร) — ค่าเริ่มต้นปิด ต้องตั้ง ALLOW_PUBLIC_REGISTER=1 บน API ด้วย
# ALLOW_PUBLIC_REGISTER=1

# TikTok: ใช้ Login Kit แยกตามเอกสาร — ยังไม่เปิดในโค้ดรอบนี้
